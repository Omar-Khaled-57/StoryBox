{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "StoryBox3",
  "version": "3.0.1",
  "identifier": "com.storybox3.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "StoryBox3",
        "width": 800,
        "height": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.ico",
      "icons/128x128@2x.png",
      "icons/128x128.png",
      "icons/icon.icns",
      "icons/32x32.png"
    ],
    "macOS": {
      "minimumSystemVersion": "10.15"
    }
  }
}
